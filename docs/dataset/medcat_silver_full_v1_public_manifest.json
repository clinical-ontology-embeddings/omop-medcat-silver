    "reason": "The generated JSONL contains MIMIC-derived sentence text, note IDs, subject IDs, admission IDs, and mention offsets. Public GitHub distribution is limited to code, documentation, and aggregate metadata."
  },
  "required_inputs": [
    {
      "name": "MIMIC-IV-Note discharge notes",
      "path": "data/01_raw/mimic-iv-note/2.2/note/discharge.csv.gz",
      "access": "PhysioNet credentialed access required; not redistributed by this repository."
    },
    {
      "name": "OMOP vocabulary v5",
      "path": "data/01_raw/vocabulary_v5",
      "access": "Local OHDSI/OMOP vocabulary download required; not redistributed by this repository."
    }
  ],
  "regeneration_command": [
    "python3",
    "scripts/build_medcat_silver_dataset.py",
    "--note-file",
    "data/01_raw/mimic-iv-note/2.2/note/discharge.csv.gz",
    "--out-root",
    "data/03_processed/text_concept_dataset/medcat_silver_full_v1",
    "--cdb-path",
    "data/03_processed/text_concept_dataset/medcat_silver_v1/medcat_omop_snomed_condition_cdb",
    "--max-notes",
    "0",
    "--min-sentence-words",
    "6",
    "--max-sentences-per-note",
    "20"
  ],
